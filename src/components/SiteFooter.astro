---
import DockwizeMark from './DockwizeMark.astro';
const cols = [
  { items: [['Starten', '/#fasen'], ['Groeien', '/#programmas'], ['Community', '/#contact'], ['Faciliteiten', '/faciliteiten'], ['Events', '/events']], strong: true },
  { items: [['Ondernemersverhalen', '#'], ['Financiering', '#'], ['Co-working', '/faciliteiten'], ['Kennis', '#'], ['Over Dockwize', '#'], ['Ons team', '#'], ['Werken bij', '#'], ['Contact', '/contact']] },
  { items: [['Kantoorruimte huren', '/faciliteiten'], ['Vergaderruimte huren', '/faciliteiten'], ['Faciliteiten', '/faciliteiten'], ['Raad van Toezicht', '#'], ['Privacy', '#'], ['Algemene voorwaarden', '#']] },
];
const socials = ['M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z', 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z', 'M22.5 6.4a2.8 2.8 0 0 0-2-2C18.9 4 12 4 12 4s-6.9 0-8.5.4a2.8 2.8 0 0 0-2 2A29 29 0 0 0 1 12a29 29 0 0 0 .5 5.6 2.8 2.8 0 0 0 2 2C5 20 12 20 12 20s6.9 0 8.5-.4a2.8 2.8 0 0 0 2-2A29 29 0 0 0 23 12a29 29 0 0 0-.5-5.6zM10 15V9l5 3z', 'M12 2c2.7 0 3 0 4.1.1 2.7.1 4 1.4 4.1 4.1.1 1.1.1 1.4.1 4.1s0 3-.1 4.1c-.1 2.7-1.4 4-4.1 4.1-1.1.1-1.4.1-4.1.1s-3 0-4.1-.1c-2.7-.1-4-1.4-4.1-4.1C3.8 15 3.8 14.7 3.8 12s0-3 .1-4.1C4 5.2 5.3 3.9 8 3.8 9.1 3.8 9.4 3.8 12 3.8zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zM17.5 6a1.2 1.2 0 1 0 0 2.4 1.2 1.2 0 0 0 0-2.4z'];
---
<footer class="bg-[var(--color-ink)] text-white">
  <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-14 pb-10">
    <!-- Newsletter -->
    <div class="rounded-[22px] bg-[var(--color-accent)] text-[var(--color-ink)] p-6 sm:p-7 flex flex-col lg:flex-row lg:items-center gap-5 lg:gap-8">
      <div class="lg:max-w-sm">
        <h3 class="text-[18px] font-extrabold tracking-tight leading-snug">Mis niets van onze kennisartikelen en spraakmakende events</h3>
        <p class="mt-1 text-[13px] font-medium text-[var(--color-ink)]/75">Schrijf je in en ontvang relevante updates en inspiratie.</p>
      </div>
      <form class="flex-1 flex flex-col sm:flex-row gap-2.5" onsubmit="return false">
        <input type="email" placeholder="Wat is je e-mailadres?" class="flex-1 h-12 rounded-full bg-white px-5 text-[14px] text-[var(--color-ink)] placeholder:text-[var(--color-ink-3)] outline-none focus:ring-2 focus:ring-[var(--color-ink)]/30" />
        <button class="inline-flex items-center justify-center gap-2 h-12 px-6 rounded-full bg-[#1b7d56] text-white text-[14px] font-semibold hover:brightness-110 transition active:scale-[0.98]">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          Verzenden
        </button>
      </form>
    </div>

    <!-- Main -->
    <div class="mt-12 grid lg:grid-cols-[1.4fr_2fr] gap-10">
      <div>
        <p class="text-[14px] leading-relaxed text-white/65 max-w-sm">Vestig je bedrijf in onze inspirerende energiecentrale, waar het bruist van de energie. De grootste ondernemers- en innovatiehub van Zeeland.</p>
        <div class="mt-6">
          <DockwizeMark size={30} dotColor="#ffffff" />
          <div class="mt-3 space-y-1.5 text-[13.5px] text-white/70">
            <p>Edisonweg 41B3, 4382 NV Vlissingen</p>
            <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> <a href="#" class="hover:text-white transition">Plan je route</a></p>
            <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2z"/></svg> <a href="tel:+31624701402" class="hover:text-white transition">+31 (0)6 24 70 14 02</a></p>
            <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="m22 6-10 7L2 6"/></svg> <a href="mailto:info@dockwize.nl" class="hover:text-white transition">info@dockwize.nl</a></p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">
        {cols.map((c) => (
          <ul class="space-y-2.5">
            {c.items.map(([label, href]) => (
              <li><a href={href} class={`text-[13.5px] transition hover:text-white ${c.strong ? 'font-bold text-white' : 'text-white/65'}`}>{label}</a></li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        {socials.map((d) => (
          <a href="#" class="grid place-items-center w-8 h-8 rounded-full bg-white/10 hover:bg-[var(--color-accent)] hover:text-[var(--color-ink)] text-white/80 transition">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d={d} /></svg>
          </a>
        ))}
      </div>
      <p class="text-[12px] text-white/45">© 2026 Dockwize · Privacy · Algemene voorwaarden · Demo door Agensea</p>
    </div>
  </div>
</footer>
