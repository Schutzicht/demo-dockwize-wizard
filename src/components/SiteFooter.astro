---
const navBig: [string, string][] = [['Starten', '/starten'], ['Groeien', '/starten'], ['Community', '/community'], ['Faciliteiten', '/faciliteiten'], ['Events', '/events']];
const col2: [string, string][][] = [
  [['Ondernemersverhalen', '#'], ['Financiering', '#'], ['Co-working', '/faciliteiten'], ['Kennis', '#']],
  [['Over Dockwize', '#'], ['Ons team', '#'], ['Werken bij', '#'], ['Contact', '/contact']],
];
const col3: [string, string][][] = [
  [['Kantoorruimte huren', '/faciliteiten'], ['Vergaderruimte huren', '/faciliteiten'], ['Faciliteiten', '/faciliteiten'], ['Raad van Toezicht', '#']],
  [['Link vrij in te vullen', '#'], ['Link vrij in te vullen', '#']],
];
const socials = ['M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z', 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z', 'M22.5 6.4a2.8 2.8 0 0 0-2-2C18.9 4 12 4 12 4s-6.9 0-8.5.4a2.8 2.8 0 0 0-2 2A29 29 0 0 0 1 12a29 29 0 0 0 .5 5.6 2.8 2.8 0 0 0 2 2C5 20 12 20 12 20s6.9 0 8.5-.4a2.8 2.8 0 0 0 2-2A29 29 0 0 0 23 12a29 29 0 0 0-.5-5.6zM10 15V9l5 3z', 'M12 2c2.7 0 3 0 4.1.1 2.7.1 4 1.4 4.1 4.1.1 1.1.1 1.4.1 4.1s0 3-.1 4.1c-.1 2.7-1.4 4-4.1 4.1-1.1.1-1.4.1-4.1.1s-3 0-4.1-.1c-2.7-.1-4-1.4-4.1-4.1C3.8 15 3.8 14.7 3.8 12s0-3 .1-4.1C4 5.2 5.3 3.9 8 3.8 9.1 3.8 9.4 3.8 12 3.8zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zM17.5 6a1.2 1.2 0 1 0 0 2.4 1.2 1.2 0 0 0 0-2.4z'];
---
<footer class="bg-[var(--color-ink)] text-white">
  <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-14 pb-10">
    <!-- Nieuwsbrief-rij: foto-D + gele kaart + telefoon + witte kaart -->
    <div class="flex items-stretch gap-6 lg:gap-10">
      <!-- Foto-gevuld D-logo -->
      <div class="hidden md:block shrink-0 self-center w-[clamp(120px,14vw,200px)]">
        <svg viewBox="91 -3 56 56" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-label="Dockwize">
          <defs>
            <clipPath id="dwdclip">
              <path d="M348.682,391.4H322.8v50h25.882a25,25,0,1,0,0-50Zm-.084,37.479h-5.042l-8.319,8.319V403.837H348.6a12.521,12.521,0,1,1,0,25.042Z" transform="translate(-229.607 -391.4)" />
            </clipPath>
          </defs>
          <image href="/images/flexwerk.jpg" x="91" y="-3" width="56" height="56" preserveAspectRatio="xMidYMid slice" clip-path="url(#dwdclip)" />
          <g transform="translate(109.832 23.782)" fill="#ffffff">
            <path d="M351.049,423.4a1.849,1.849,0,1,0-1.849-1.849A1.865,1.865,0,0,0,351.049,423.4Z" transform="translate(-343.654 -419.7)" />
            <ellipse cx="1.849" cy="1.849" rx="1.849" ry="1.849" />
            <ellipse cx="1.849" cy="1.849" rx="1.849" ry="1.849" transform="translate(11.092 0)" />
          </g>
        </svg>
      </div>

      <!-- Bar: gele kaart + witte kaart + telefoon -->
      <div class="relative flex-1">
        <div class="grid grid-cols-1 sm:grid-cols-2 rounded-[22px] overflow-hidden">
          <div class="bg-[var(--color-accent)] text-[var(--color-ink)] p-6 sm:p-8 flex flex-col justify-center">
            <h3 class="text-[18px] sm:text-[20px] font-extrabold tracking-tight leading-snug max-w-xs">Mis niets van onze kennisartikelen en spraakmakende events</h3>
            <p class="mt-1.5 text-[13px] font-medium text-[var(--color-ink)]/75">Schrijf je in en ontvang relevante updates en inspiratie.</p>
          </div>
          <div class="bg-white text-[var(--color-ink)] p-6 sm:p-8 sm:pl-16 flex flex-col justify-center">
            <span class="text-[13px] font-semibold">E-mailadres</span>
            <form class="mt-2 flex items-center gap-4" onsubmit="return false">
              <input type="email" placeholder="Wat is je e-mailadres?" class="flex-1 min-w-0 bg-transparent border-b-2 border-[var(--color-ink)]/15 focus:border-[var(--color-ink)] outline-none py-1.5 text-[14px] placeholder:text-[var(--color-ink-3)] transition" />
              <button class="shrink-0 inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white px-5 py-2.5 text-[14px] font-semibold hover:brightness-110 transition active:scale-95">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                Verzenden
              </button>
            </form>
          </div>
        </div>
        <!-- Telefoon-mockup over de naad -->
        <div class="hidden sm:block absolute left-1/2 -translate-x-1/2 -top-6 z-10">
          <div class="relative w-[80px] h-[156px] rounded-[18px] bg-[var(--color-ink)] p-[3px] shadow-[var(--shadow-xl)]">
            <div class="w-full h-full rounded-[15px] bg-[var(--color-accent)] grid place-items-center">
              <span class="text-[9px] font-medium text-[var(--color-ink)]/80 text-center leading-tight px-2">screenshot van nieuwsbrief</span>
            </div>
            <div class="absolute top-[5px] left-1/2 -translate-x-1/2 w-7 h-1.5 rounded-full bg-[var(--color-ink)]"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hoofdblok: tagline + adres | 3 nav-kolommen -->
    <div class="mt-14 grid gap-10 lg:grid-cols-[1.25fr_0.8fr_1.05fr_1.05fr]">
      <div>
        <p class="text-[14.5px] leading-relaxed text-white/65 max-w-xs">Vestig je bedrijf in onze inspirerende energiecentrale, waar het bruist van de energie. De grootste ondernemers- en innovatiehub van Zeeland.</p>
        <p class="mt-6 text-[15px] font-extrabold text-[var(--color-accent)]">Dockwize</p>
        <div class="mt-2 space-y-1.5 text-[13.5px] text-white/70">
          <p>Edisonweg 41 B3</p>
          <p>4382 NV Vlissingen</p>
          <p class="flex items-center gap-2 pt-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> <a href="#" class="hover:text-white transition">Plan je route</a></p>
          <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2z"/></svg> <a href="tel:+31624701402" class="hover:text-white transition">+31 (0)6 24 70 14 02</a></p>
          <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="m22 6-10 7L2 6"/></svg> <a href="mailto:info@dockwize.nl" class="hover:text-white transition">info@dockwize.nl</a></p>
        </div>
      </div>

      <!-- Kolom 1: groot -->
      <ul class="space-y-3">
        {navBig.map(([label, href]) => (
          <li class="flex items-center gap-2.5">
            <span class="w-1 h-1 rounded-full bg-white/40 shrink-0"></span>
            <a href={href} class="text-[clamp(1.3rem,1.7vw,1.6rem)] font-extrabold tracking-tight text-white hover:text-[var(--color-accent)] transition">{label}</a>
          </li>
        ))}
      </ul>

      <!-- Kolom 2 -->
      <div class="space-y-5">
        {col2.map((group) => (
          <ul class="space-y-2.5">
            {group.map(([label, href]) => (
              <li><a href={href} class="text-[14px] text-white/65 hover:text-white transition">{label}</a></li>
            ))}
          </ul>
        ))}
      </div>

      <!-- Kolom 3 -->
      <div class="space-y-5">
        {col3.map((group) => (
          <ul class="space-y-2.5">
            {group.map(([label, href]) => (
              <li><a href={href} class="text-[14px] text-white/65 hover:text-white transition">{label}</a></li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <!-- Onderbalk -->
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-2.5 order-2 sm:order-none">
        {socials.map((d) => (
          <a href="#" class="grid place-items-center w-9 h-9 rounded-full bg-white/10 hover:bg-[var(--color-accent)] hover:text-[var(--color-ink)] text-white/80 transition">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d={d} /></svg>
          </a>
        ))}
      </div>
      <p class="text-[12.5px] text-white/45 order-3 sm:order-none">© 2026 Dockwize &nbsp;·&nbsp; <a href="#" class="hover:text-white transition">Privacy</a> &nbsp;·&nbsp; <a href="#" class="hover:text-white transition">Algemene voorwaarden</a></p>
      <p class="text-[12.5px] text-white/45 order-1 sm:order-none">Website door <a href="#" class="underline underline-offset-2 hover:text-white transition">Nedbase</a></p>
    </div>
  </div>
</footer>
