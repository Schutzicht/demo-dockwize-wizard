---
// Groot uitklapmenu (2 panelen, afgeronde hoeken): geel nav-paneel links, donkere promo rechts.
// Openen: elk element met data-dw-menu. Sluiten: data-dw-close / backdrop / Esc.
const primary = [
  ['Home', '/'], ['Starten', '/starten'], ['Groeien', '/starten'], ['Community', '/community'], ['Faciliteiten', '/faciliteiten'], ['Events', '/events'],
];
const secA = [['Ondernemersverhalen', '#'], ['Financiering', '#'], ['Co-working', '/faciliteiten'], ['Kennis', '#']];
const secB = [['Over Dockwize', '#'], ['Ons team', '#'], ['Werken bij', '#'], ['Contact', '/contact']];
---
<div id="dw-menu" class="fixed inset-0 z-[95] hidden">
  <div id="dw-menu-bd" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
  <div id="dw-menu-sheet" class="absolute inset-0 lg:inset-6 lg:rounded-[28px] overflow-hidden grid lg:grid-cols-[0.82fr_1fr] shadow-[var(--shadow-xl)]"
       style="opacity:0; transform:scale(0.985); transition:opacity 300ms ease, transform 420ms var(--ease-out-quint);">
    <!-- Links: gele navigatie -->
    <div class="relative bg-[var(--color-accent)] p-8 sm:p-12 lg:p-14 overflow-y-auto">
      <button data-dw-close aria-label="Sluiten" class="lg:hidden absolute top-6 right-6 grid place-items-center w-10 h-10 rounded-full bg-[var(--color-ink)]/10 text-[var(--color-ink)] active:scale-95 transition">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <nav class="flex flex-col gap-1.5 sm:gap-2">
        {primary.map(([l, h]) => (
          <a href={h} class="w-fit text-[clamp(1.7rem,3.2vw,2.3rem)] font-extrabold tracking-tight text-[var(--color-ink)] hover:opacity-60 transition">{l}</a>
        ))}
      </nav>
      <div class="mt-9 sm:mt-12 grid grid-cols-2 gap-x-8 gap-y-2.5 max-w-md">
        <div class="space-y-2.5">{secA.map(([l, h]) => <a href={h} class="w-fit block text-[14px] font-medium text-[var(--color-ink)]/65 hover:text-[var(--color-ink)] transition">{l}</a>)}</div>
        <div class="space-y-2.5">{secB.map(([l, h]) => <a href={h} class="w-fit block text-[14px] font-medium text-[var(--color-ink)]/65 hover:text-[var(--color-ink)] transition">{l}</a>)}</div>
      </div>
    </div>
    <!-- Rechts: donkere promo -->
    <div class="hidden lg:flex relative bg-[var(--color-ink)] p-8 lg:p-10 flex-col">
      <button data-dw-close class="self-end inline-flex items-center gap-2 text-[var(--color-accent)] font-bold text-[14px] hover:opacity-70 transition">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        Sluiten
      </button>
      <div class="mt-10">
        <h3 class="text-[clamp(1.5rem,2.2vw,2rem)] font-extrabold text-[var(--color-accent)] leading-tight max-w-xs text-balance">Inspirerende vergaderruimtes bij Dockwize</h3>
        <a href="/faciliteiten" class="mt-6 inline-flex items-center gap-2 rounded-xl bg-[var(--color-cta)] text-white px-4 py-2.5 text-[14px] font-semibold hover:brightness-110 transition active:scale-95">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
          Boek een ruimte
        </a>
      </div>
      <div class="mt-auto pt-8">
        <div class="rounded-[20px] overflow-hidden"><img src="/images/collab.jpg" alt="Vergaderen bij Dockwize" class="w-full h-[clamp(200px,30vh,340px)] object-cover" /></div>
      </div>
    </div>
  </div>
</div>
<script is:inline>
  (function () {
    const m = document.getElementById('dw-menu'); if (!m) return;
    const bd = document.getElementById('dw-menu-bd'), sh = document.getElementById('dw-menu-sheet');
    const open = () => { m.classList.remove('hidden'); document.body.style.overflow = 'hidden'; requestAnimationFrame(() => { bd.style.opacity = '1'; sh.style.opacity = '1'; sh.style.transform = 'none'; }); };
    const close = () => { bd.style.opacity = '0'; sh.style.opacity = '0'; sh.style.transform = 'scale(0.985)'; document.body.style.overflow = ''; setTimeout(() => m.classList.add('hidden'), 320); };
    document.addEventListener('click', (e) => {
      if (e.target.closest('[data-dw-menu]')) { e.preventDefault(); open(); return; }
      if (e.target.closest('[data-dw-close]')) { close(); }
    });
    bd.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !m.classList.contains('hidden')) close(); });
  })();
</script>
