---
import DockwizeMark from './DockwizeMark.astro';
import SiteMenu from './SiteMenu.astro';
interface Props {
  variant?: 'dark' | 'light'; // dark = donkere achtergrond (witte nav), light = gele/lichte achtergrond (donkere nav)
  active?: string;
}
const { variant = 'dark', active = '' } = Astro.props;
const dark = variant === 'dark';
const nav = [
  { label: 'Starten', href: '/starten' },
  { label: 'Groeien', href: '/starten' },
  { label: 'Community', href: '/community' },
  { label: 'Faciliteiten', href: '/faciliteiten' },
  { label: 'Events', href: '/events' },
];
const base = dark ? 'text-white/85 hover:text-white' : 'text-[var(--color-ink-2)] hover:text-[var(--color-ink)]';
const activeCls = dark ? 'text-white font-semibold' : 'text-[var(--color-ink)] font-bold';
---
<header class="absolute top-0 inset-x-0 z-40">
  <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-6 flex items-center justify-between gap-4">
    <a href="/" aria-label="Dockwize" class="shrink-0">
      <DockwizeMark size={36} markColor={dark ? '#ffda00' : '#1d1d1b'} dotColor={dark ? '#ffffff' : '#ffda00'} />
    </a>
    <nav class="hidden md:flex items-center gap-6">
      {nav.map((n) => (
        <a href={n.href} class={`text-[14px] font-medium transition ${active === n.label ? activeCls : base}`}>{n.label}</a>
      ))}
      <button data-dw-menu class="ml-1 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold hover:brightness-105 transition active:scale-95">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        Menu
      </button>
    </nav>
    <button data-dw-menu class="md:hidden inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold active:scale-95">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      Menu
    </button>
  </div>
</header>

<SiteMenu />
