---
import DockwizeMark from './DockwizeMark.astro';
interface Props {
  variant?: 'dark' | 'light'; // dark = donkere achtergrond (witte nav), light = gele/lichte achtergrond (donkere nav)
  active?: string;
}
const { variant = 'dark', active = '' } = Astro.props;
const dark = variant === 'dark';
const nav = [
  { label: 'Starten', href: '/starten' },
  { label: 'Groeien', href: '/starten' },
  { label: 'Community', href: '/community' },
  { label: 'Faciliteiten', href: '/faciliteiten' },
  { label: 'Events', href: '/events' },
];
const base = dark ? 'text-white/85 hover:text-white' : 'text-[var(--color-ink-2)] hover:text-[var(--color-ink)]';
const activeCls = dark ? 'text-white font-semibold' : 'text-[var(--color-ink)] font-bold';
---
<header class="absolute top-0 inset-x-0 z-40">
  <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-6 flex items-center justify-between gap-4">
    <a href="/" aria-label="Dockwize" class="shrink-0">
      <DockwizeMark size={36} markColor={dark ? '#ffda00' : '#1d1d1b'} dotColor={dark ? '#ffffff' : '#ffda00'} />
    </a>
    <nav class="hidden md:flex items-center gap-6">
      {nav.map((n) => (
        <a href={n.href} class={`text-[14px] font-medium transition ${active === n.label ? activeCls : base}`}>{n.label}</a>
      ))}
      <button id="dwh-menu" class="ml-1 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold hover:brightness-105 transition active:scale-95">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        Menu
      </button>
    </nav>
    <button id="dwh-menu-m" class={`md:hidden inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold active:scale-95`}>
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      Menu
    </button>
  </div>

  <!-- Menu overlay -->
  <div id="dwh-panel" class="fixed inset-0 z-[80] hidden">
    <div id="dwh-backdrop" class="absolute inset-0 bg-[var(--color-ink)]/40 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
    <div id="dwh-sheet" class="absolute top-4 right-4 left-4 sm:left-auto sm:w-[360px] rounded-[24px] bg-[var(--color-surface)] shadow-[var(--shadow-xl)] p-6 -translate-y-3 opacity-0 transition-all duration-300" style="transition-timing-function:var(--ease-out-quint);">
      <div class="flex items-center justify-between">
        <DockwizeMark size={30} dotColor="#1d1d1b" />
        <button id="dwh-close" aria-label="Sluiten" class="grid place-items-center w-9 h-9 rounded-full text-[var(--color-ink-3)] hover:bg-[var(--color-surface-2)] transition active:scale-95">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <nav class="mt-5 flex flex-col">
        {nav.map((n, i) => (
          <a href={n.href} class={`py-3 text-[16px] font-bold text-[var(--color-ink)] hover:text-[var(--color-ink-2)] transition ${i > 0 ? 'border-t border-[var(--color-border)]' : ''}`}>{n.label}</a>
        ))}
        <a href="/contact" class="py-3 text-[16px] font-bold text-[var(--color-ink)] hover:text-[var(--color-ink-2)] transition border-t border-[var(--color-border)]">Contact</a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const panel = document.getElementById('dwh-panel');
    const backdrop = document.getElementById('dwh-backdrop');
    const sheet = document.getElementById('dwh-sheet');
    if (!panel) return;
    const open = () => { panel.classList.remove('hidden'); requestAnimationFrame(() => { backdrop.style.opacity = '1'; sheet.style.opacity = '1'; sheet.style.transform = 'none'; }); };
    const close = () => { backdrop.style.opacity = '0'; sheet.style.opacity = '0'; sheet.style.transform = 'translateY(-12px)'; setTimeout(() => panel.classList.add('hidden'), 300); };
    document.getElementById('dwh-menu')?.addEventListener('click', open);
    document.getElementById('dwh-menu-m')?.addEventListener('click', open);
    document.getElementById('dwh-close')?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
  })();
</script>
