---
// Eén gedeelde event-kaart (identiek op home én /events), exact zoals dockwize.nl
interface Props {
  event: { slug: string; title: string; type: string; day: string; month: string; time: string; location: string; image: string };
}
const { event: e } = Astro.props;
---
<a href={`/events/${e.slug}`} class="group h-full flex flex-col rounded-[18px] bg-[var(--color-surface)] border border-[var(--color-border)] shadow-[var(--shadow-sm)] hover:shadow-[var(--shadow-lg)] hover:-translate-y-0.5 transition overflow-hidden" style="transition-timing-function:var(--ease-out-quint);">
  <div class="relative">
    <img src={e.image} alt={e.title} class="h-48 w-full object-cover" />
    <span class="absolute top-4 left-4 grid place-items-center w-12 h-12 rounded-[10px] bg-[var(--color-accent)] text-[var(--color-ink)] leading-none shadow-md">
      <span class="text-[18px] font-extrabold">{e.day}</span>
      <span class="text-[10px] font-semibold -mt-0.5">{e.month}</span>
    </span>
  </div>
  <div class="p-5 flex flex-col flex-1">
    <span class="self-start text-[11px] font-medium text-[var(--color-ink-2)] bg-[var(--color-surface-2)] rounded-full px-2.5 py-1">{e.type}</span>
    <h3 class="mt-3 text-[16px] font-bold leading-snug text-[var(--color-ink)]">{e.title}</h3>
    <div class="mt-3 space-y-1.5 text-[12.5px] text-[var(--color-ink-3)]">
      <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> {e.location}</p>
      <p class="flex items-center gap-2"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> {e.time}</p>
    </div>
    <span class="mt-5 self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[13px] font-semibold group-hover:brightness-110 transition">
      <span class="grid place-items-center w-6 h-6 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      Event bekijken
    </span>
  </div>
</a>
