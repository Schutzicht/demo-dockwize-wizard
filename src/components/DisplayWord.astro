---
// Reuze tussenwoord dat ÁCHTER de eropvolgende content valt: de onderkant van het
// woord wordt overlapt door het volgende (ondoorzichtige) blok, de bovenkant steekt eruit.
interface Props {
  word: string;
  align?: 'left' | 'center' | 'right';
  class?: string;
}
const { word, align = 'left', class: cls = '' } = Astro.props;
const j = align === 'center' ? 'text-center' : align === 'right' ? 'text-right' : 'text-left';
---
<div class={`overflow-hidden leading-[0.74] select-none px-6 sm:px-10 lg:px-16 -mb-[clamp(1.5rem,6.5vw,6.5rem)] ${j} ${cls}`} aria-hidden="true">
  <span class="inline-block font-extrabold tracking-[-0.06em] text-[var(--color-accent)] text-[clamp(5rem,21vw,19rem)]">{word}</span>
</div>
