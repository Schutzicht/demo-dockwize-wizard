---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import GroeiscanWidget from '../../components/GroeiscanWidget.astro';
import { FACILITIES } from '../../data/facilities';

export function getStaticPaths() {
  return FACILITIES.map((f) => ({ params: { slug: f.slug }, props: { f } }));
}
const { f } = Astro.props;
const specs = [
  ['Capaciteit', f.capacity],
  ['Oppervlakte', f.area],
  ['Faciliteiten', f.features],
  ['Kosten', f.price],
];
const voorzieningen = [
  'Betrouwbare wifi-connectie',
  'Beamer en witte muur voor duidelijke presentaties',
  'Flip-over voor interactieve sessies',
  'HDMI-aansluiting voor gemakkelijk verbinden met de beamer',
  'Meet-up tool voor groepen die hybride vergaderen (alleen op aanvraag)',
  'Cateringopties via Brasserie PZEM 41',
];
---

<Base title={`Vergaderruimte ${f.name} — Dockwize`}>
  <SiteHeader variant="light" active="Faciliteiten" />

  <!-- Hero (geel) -->
  <section class="bg-[var(--color-accent)]">
    <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-28 sm:pt-32 pb-10">
      <p class="text-[12px] text-[var(--color-ink)]/55 font-medium">Faciliteiten &nbsp;›&nbsp; Vergaderruimtes &nbsp;›&nbsp; {f.name}</p>
      <h1 class="mt-3 font-extrabold tracking-[-0.03em] leading-tight text-[clamp(2rem,5vw,3.2rem)] text-[var(--color-ink)]">Vergaderruimte {f.name}</h1>
      <div class="mt-7 flex flex-col lg:flex-row lg:items-end justify-between gap-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {specs.map(([label, val]) => (
            <div>
              <p class="text-[12px] font-bold text-[var(--color-ink)]">{label}</p>
              <p class="text-[12.5px] text-[var(--color-ink)]/70 mt-0.5">{val}</p>
            </div>
          ))}
        </div>
        <a href="#reserveren" class="shrink-0 inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[13.5px] font-semibold hover:brightness-110 transition active:scale-95">
          <span class="grid place-items-center w-7 h-7 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></span>
          Direct reserveren
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-[900px] px-6 sm:px-10 py-14 sm:py-16">
    <p class="text-[16px] sm:text-[18px] leading-relaxed text-[var(--color-ink-2)] text-pretty">De {f.name} is een veelzijdige en ruime zaal voor verschillende evenementen zoals lezingen, presentaties, trainingen en seminars. De {f.name}-zaal heeft ruimte tot {f.capacityShort.replace('Tot ', '').replace(' personen', '')} personen en biedt vele opties voor zowel kleine als grote groepen.</p>

    <div class="mt-8 rounded-[20px] overflow-hidden shadow-[var(--shadow-lg)]">
      <img src={f.image} alt={`Vergaderruimte ${f.name}`} class="w-full h-[clamp(240px,40vw,440px)] object-cover" />
    </div>

    <div class="mt-12">
      <h2 class="text-[20px] font-extrabold tracking-tight text-[var(--color-ink)]">Alle voorzieningen voor een succesvol evenement</h2>
      <p class="mt-2 text-[14px] text-[var(--color-ink-2)]">De {f.name}-zaal is voorzien van moderne faciliteiten om je evenement vlekkeloos te laten verlopen:</p>
      <ul class="mt-4 space-y-2.5">
        {voorzieningen.map((v) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 shrink-0 text-[var(--color-cta)]"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></span>
            <span class="text-[14px] text-[var(--color-ink-2)] leading-snug">{v}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-10">
      <h2 class="text-[20px] font-extrabold tracking-tight text-[var(--color-ink)]">Betaalbaar en toegankelijk vergaderen</h2>
      <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-ink-2)]">Met {f.price.toLowerCase()} vergader je in de {f.name}-zaal binnen elk budget, van kleinschalig tot grote evenementen. De vergaderruimte ligt centraal, goed bereikbaar via het NS-station Vlissingen en de A58. Bij Dockwize parkeer je gratis en er is een laadpunt voor elektrische auto’s beschikbaar.</p>
    </div>

    <div class="mt-10">
      <h2 class="text-[20px] font-extrabold tracking-tight text-[var(--color-ink)]">Plan je volgende evenement bij Dockwize</h2>
      <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-ink-2)]">Bij Dockwize bruist het van de energie van startups en innovatieve ondernemers. Laat jij je ook inspireren tijdens je volgende meeting? Reserveer deze zaal makkelijk online of telefonisch via de receptie: <a href="tel:+31644114121" class="text-[var(--color-cta)] font-semibold">+31 (0)6 44 11 41 21</a>.</p>
      <a href="/contact" class="mt-6 inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[13.5px] font-semibold hover:brightness-110 transition active:scale-95">
        <span class="grid place-items-center w-7 h-7 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></span>
        Praat met de receptie
      </a>
    </div>
  </section>

  <!-- Reserveren -->
  <section id="reserveren" class="bg-[var(--color-surface-2)] scroll-mt-20">
    <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 py-16 sm:py-20 grid lg:grid-cols-[0.85fr_1.4fr] gap-8 lg:gap-12 items-start">
      <div class="rounded-[22px] bg-[var(--color-accent)] p-7">
        <div class="w-16 h-16 rounded-full overflow-hidden ring-4 ring-white/40"><img src="/images/hero.jpg" alt="" class="w-full h-full object-cover" /></div>
        <h2 class="mt-4 text-[20px] font-extrabold tracking-tight text-[var(--color-ink)] leading-snug">Hulp of inspiratie nodig voor het boeken van deze ruimte?</h2>
        <p class="mt-2 text-[13.5px] text-[var(--color-ink)]/75 leading-relaxed">Ons team denkt graag met je mee over de juiste opstelling, catering en planning voor jouw bijeenkomst.</p>
        <div class="mt-5 space-y-2.5">
          <a href="#" class="flex items-center gap-3 text-[13.5px] font-semibold text-[var(--color-ink)]"><span class="grid place-items-center w-9 h-9 rounded-full bg-[var(--color-ink)] text-[var(--color-accent)]"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span> Start een chat</a>
          <a href="tel:+31644114121" class="flex items-center gap-3 text-[13.5px] font-semibold text-[var(--color-ink)]"><span class="grid place-items-center w-9 h-9 rounded-full bg-[var(--color-ink)] text-[var(--color-accent)]"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2z"/></svg></span> +31 (0)6 44 11 41 21</a>
          <a href="mailto:info@dockwize.nl" class="flex items-center gap-3 text-[13.5px] font-semibold text-[var(--color-ink)]"><span class="grid place-items-center w-9 h-9 rounded-full bg-[var(--color-ink)] text-[var(--color-accent)]"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="m22 6-10 7L2 6"/></svg></span> info@dockwize.nl</a>
        </div>
      </div>

      <div class="rounded-[22px] bg-[var(--color-surface)] border border-[var(--color-border)] shadow-[var(--shadow-sm)] p-7">
        <h2 class="text-[20px] font-extrabold tracking-tight text-[var(--color-ink)]">Vergaderzaal {f.name} reserveren</h2>
        <form class="mt-5 grid sm:grid-cols-2 gap-4" onsubmit="return false">
          <label class="block"><span class="text-[12px] font-medium text-[var(--color-ink-2)]">Naam</span><input type="text" placeholder="In dit veld wordt getypt…" class="mt-1 w-full h-11 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-[13.5px] outline-none focus:border-[var(--color-ink)] focus:ring-2 focus:ring-[var(--color-accent)]/40 transition" /></label>
          <label class="block"><span class="text-[12px] font-medium text-[var(--color-ink-2)]">Bedrijfsnaam</span><input type="text" placeholder="Hoe heet je bedrijf?" class="mt-1 w-full h-11 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-[13.5px] outline-none focus:border-[var(--color-ink)] focus:ring-2 focus:ring-[var(--color-accent)]/40 transition" /></label>
          <label class="block"><span class="text-[12px] font-medium text-[var(--color-ink-2)]">E-mailadres</span><input type="email" placeholder="Wat is je e-mailadres?" class="mt-1 w-full h-11 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-[13.5px] outline-none focus:border-[var(--color-ink)] focus:ring-2 focus:ring-[var(--color-accent)]/40 transition" /></label>
          <label class="block"><span class="text-[12px] font-medium text-[var(--color-ink-2)]">Telefoonnummer <span class="text-[var(--color-ink-3)] font-normal">(optioneel)</span></span><input type="tel" placeholder="Hoe kunnen we je bereiken?" class="mt-1 w-full h-11 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-[13.5px] outline-none focus:border-[var(--color-ink)] focus:ring-2 focus:ring-[var(--color-accent)]/40 transition" /></label>
          <label class="block sm:col-span-2"><span class="text-[12px] font-medium text-[var(--color-ink-2)]">Bericht <span class="text-[var(--color-ink-3)] font-normal">(optioneel)</span></span><textarea rows="3" placeholder="Wil je alvast iets over jezelf en je bedrijf vertellen?" class="mt-1 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-[13.5px] outline-none focus:border-[var(--color-ink)] focus:ring-2 focus:ring-[var(--color-accent)]/40 transition resize-none"></textarea></label>
          <label class="sm:col-span-2 flex items-start gap-2.5 cursor-pointer"><input type="checkbox" class="mt-0.5 w-4 h-4 accent-[var(--color-ink)]" /><span class="text-[12px] leading-snug text-[var(--color-ink-3)]">Ik ga akkoord met de verwerking van mijn persoonsgegevens zoals beschreven in de privacyverklaring.</span></label>
          <div class="sm:col-span-2">
            <button class="inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2.5 text-[13.5px] font-semibold hover:brightness-110 transition active:scale-95"><span class="grid place-items-center w-7 h-7 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span> Verzenden</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <SiteFooter />
  <GroeiscanWidget contactUrl="#" />
</Base>
