---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GroeiscanWidget from '../components/GroeiscanWidget.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { EVENTS } from '../data/events';

const pinIcon = '<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>';
const clockIcon = '<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>';
---

<Base title="Events — Dockwize">
  <SiteHeader variant="light" active="Events" />

  <div class="bg-[var(--color-accent)]">
    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-28 sm:pt-32 pb-8">
      <Breadcrumb items={[['Events', '/events']]} />
      <h1 class="mt-5 font-extrabold tracking-[-0.03em] leading-[1.05] text-[clamp(2rem,5vw,3.4rem)] text-[var(--color-ink)] max-w-3xl text-balance">Ontmoet, deel je kennis en raak geïnspireerd</h1>
      <div class="mt-8 border-t-2 border-dotted border-[var(--color-ink)]/30"></div>
      <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-5">
        <label class="inline-flex items-center gap-2 shrink-0 text-[13px] font-semibold text-[var(--color-ink)]">Toon events per categorie
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-ink)] text-white px-3.5 py-1.5">Alles <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg></span>
        </label>
        <p class="text-[13.5px] text-[var(--color-ink)]/70 max-w-xl">Wij organiseren events waar je kennis, ervaring en expertise opdoet. Je netwerk wordt vergroot en onze events worden gefaciliteerd. Ontmoetingen worden gefaciliteerd om werkbare lat erei of een samenwerking aan te gaan.</p>
      </div>
    </section>

    <!-- Grid -->
    <section class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pb-4">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {EVENTS.slice(0, 2).map((e) => (
          <a href={`/events/${e.slug}`} class="group rounded-[18px] bg-[var(--color-surface)] overflow-hidden shadow-[var(--shadow-md)] hover:shadow-[var(--shadow-lg)] hover:-translate-y-0.5 transition flex flex-col" style="transition-timing-function:var(--ease-out-quint);">
            <div class="relative">
              <img src={e.image} alt={e.title} class="h-44 w-full object-cover" />
              <span class="absolute top-3 left-3 grid place-items-center w-12 h-12 rounded-xl bg-[var(--color-accent)] text-[var(--color-ink)] leading-none shadow"><span class="text-[18px] font-extrabold">{e.day}</span><span class="text-[10px] font-semibold uppercase -mt-0.5">{e.month}</span></span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <span class="text-[11px] font-semibold text-[var(--color-ink-3)] uppercase tracking-wide">{e.type}</span>
              <h3 class="mt-1.5 text-[16px] font-bold leading-snug text-[var(--color-ink)]">{e.title}</h3>
              <div class="mt-3 space-y-1 text-[12px] text-[var(--color-ink-3)]">
                <p class="flex items-center gap-1.5" set:html={pinIcon + ' ' + e.location}></p>
                <p class="flex items-center gap-1.5" set:html={clockIcon + ' ' + e.time}></p>
              </div>
              <span class="mt-4 self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-4 py-1.5 text-[12.5px] font-semibold group-hover:brightness-110 transition"><span class="grid place-items-center w-6 h-6 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span> Event bekijken</span>
            </div>
          </a>
        ))}
        <!-- Zelf organiseren -->
        <div class="rounded-[18px] bg-[var(--color-ink)] text-white overflow-hidden flex flex-col">
          <div class="relative h-40 shrink-0">
            <img src="/images/hero.jpg" alt="" class="w-full h-full object-cover opacity-35" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)] via-[var(--color-ink)]/40 to-transparent"></div>
            <span class="absolute left-5 top-6 grid place-items-center w-11 h-11 rounded-full bg-[var(--color-cta)] text-white shadow-lg"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
            <span class="absolute right-6 top-10 grid place-items-center w-12 h-12 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] shadow-lg"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <span class="absolute left-1/2 -translate-x-1/2 bottom-3 grid place-items-center w-10 h-10 rounded-full bg-white/15 backdrop-blur text-white"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/></svg></span>
          </div>
          <div class="p-6 pt-4 flex flex-col flex-1">
            <h3 class="text-[18px] font-extrabold tracking-tight text-[var(--color-accent)]">Zelf een event organiseren?</h3>
            <p class="mt-1.5 text-[12.5px] leading-relaxed text-white/65">Organiseer jouw evenement in Innovatiepunt KAAP en bereik ondernemend Zeeland. We denken graag met je mee over opzet, techniek en promotie.</p>
            <a href="/contact" class="mt-4 self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[12.5px] font-semibold hover:brightness-110 transition active:scale-95"><span class="grid place-items-center w-6 h-6 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></span> Call-to-action</a>
          </div>
        </div>
        {EVENTS.slice(2).map((e) => (
          <a href={`/events/${e.slug}`} class="group rounded-[18px] bg-[var(--color-surface)] overflow-hidden shadow-[var(--shadow-md)] hover:shadow-[var(--shadow-lg)] hover:-translate-y-0.5 transition flex flex-col" style="transition-timing-function:var(--ease-out-quint);">
            <div class="relative">
              <img src={e.image} alt={e.title} class="h-44 w-full object-cover" />
              <span class="absolute top-3 left-3 grid place-items-center w-12 h-12 rounded-xl bg-[var(--color-accent)] text-[var(--color-ink)] leading-none shadow"><span class="text-[18px] font-extrabold">{e.day}</span><span class="text-[10px] font-semibold uppercase -mt-0.5">{e.month}</span></span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <span class="text-[11px] font-semibold text-[var(--color-ink-3)] uppercase tracking-wide">{e.type}</span>
              <h3 class="mt-1.5 text-[16px] font-bold leading-snug text-[var(--color-ink)]">{e.title}</h3>
              <div class="mt-3 space-y-1 text-[12px] text-[var(--color-ink-3)]">
                <p class="flex items-center gap-1.5" set:html={pinIcon + ' ' + e.location}></p>
                <p class="flex items-center gap-1.5" set:html={clockIcon + ' ' + e.time}></p>
              </div>
              <span class="mt-4 self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-4 py-1.5 text-[12.5px] font-semibold group-hover:brightness-110 transition"><span class="grid place-items-center w-6 h-6 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span> Event bekijken</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Paginatie -->
      <div class="mt-10 flex items-center justify-center gap-1.5 text-[13px]">
        <button class="grid place-items-center w-9 h-9 rounded-full border border-[var(--color-ink)]/20 text-[var(--color-ink)] hover:bg-[var(--color-ink)]/5 transition"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg></button>
        <button class="grid place-items-center w-9 h-9 rounded-full bg-[var(--color-ink)] text-white font-semibold">1</button>
        <button class="grid place-items-center w-9 h-9 rounded-full text-[var(--color-ink)] hover:bg-[var(--color-ink)]/5 transition font-semibold">2</button>
        <span class="px-1 text-[var(--color-ink)]/50">…</span>
        <button class="grid place-items-center w-9 h-9 rounded-full text-[var(--color-ink)] hover:bg-[var(--color-ink)]/5 transition font-semibold">8</button>
        <button class="grid place-items-center w-9 h-9 rounded-full border border-[var(--color-ink)]/20 text-[var(--color-ink)] hover:bg-[var(--color-ink)]/5 transition"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg></button>
      </div>
    </section>
  </div>

  <!-- Zelf organiseren sectie -->
  <section class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 py-16 sm:py-24">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <h2 class="text-[clamp(1.6rem,3.5vw,2.4rem)] font-extrabold tracking-tight text-[var(--color-ink)]">Zelf een evenement organiseren?</h2>
        <p class="mt-4 text-[14.5px] leading-relaxed text-[var(--color-ink-2)]">Innovatiepunt KAAP is de ideale plek voor jouw event. Met flexibele zalen, hoogwaardige catering en een community van ondernemers bereik je precies de mensen die je zoekt. Wij denken graag mee over opzet, techniek en promotie.</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[13.5px] font-semibold hover:brightness-110 transition active:scale-95"><span class="grid place-items-center w-7 h-7 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></span> Plan je event</a>
          <a href="/faciliteiten" class="inline-flex items-center rounded-full border border-[var(--color-border-strong)] px-5 py-2.5 text-[13.5px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-surface-2)] transition active:scale-95">Bekijk de zalen</a>
        </div>
      </div>
      <div class="rounded-[20px] overflow-hidden shadow-[var(--shadow-lg)]"><img src="/images/hero.jpg" alt="" class="w-full h-[clamp(240px,30vw,360px)] object-cover" /></div>
    </div>
  </section>

  <SiteFooter />
  <GroeiscanWidget contactUrl="#" />
</Base>
