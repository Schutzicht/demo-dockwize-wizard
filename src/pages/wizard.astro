---
import Base from '../layouts/Base.astro';
import DockwizeLogo from '../components/DockwizeLogo.astro';
import GroeiscanWidget from '../components/GroeiscanWidget.astro';
---

<Base title="Dockwize Groeiscan">
  <main class="min-h-[100dvh] grid place-items-center px-5">
    <div class="max-w-md text-center">
      <div class="flex justify-center"><DockwizeLogo size={30} /></div>
      <h1 class="mt-8 text-[clamp(1.8rem,6vw,2.6rem)] leading-tight font-semibold tracking-tight text-[var(--color-ink)] text-balance">In welke fase zit jouw bedrijf?</h1>
      <p class="mt-4 text-[15px] leading-relaxed text-[var(--color-ink-2)]">Doe de gratis Groeiscan en ontdek in 2 minuten je groeifase, je openstaande stappen en het Dockwize-programma dat bij je past.</p>
      <button type="button" data-dwq-open class="mt-8 inline-flex items-center justify-center gap-2 h-12 px-7 rounded-full bg-[var(--color-ink)] text-white text-[14px] font-semibold hover:-translate-y-px transition active:scale-[0.98]" style="transition-timing-function:var(--ease-out-quint);">
        Start de Groeiscan
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>
  </main>

  <GroeiscanWidget contactUrl="#" autoTeaser={false} />

  <script is:inline>
    // auto-open net na load (klikt de launcher, die via [data-dwq-open] de scan opent)
    window.addEventListener('load', () => setTimeout(() => document.getElementById('dwq-launch')?.click(), 350));
  </script>
</Base>
