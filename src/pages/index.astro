---
import Base from '../layouts/Base.astro';
import DockwizeWordmark from '../components/DockwizeWordmark.astro';
import DockwizeMark from '../components/DockwizeMark.astro';
import GroeiscanWidget from '../components/GroeiscanWidget.astro';
import SiteMenu from '../components/SiteMenu.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DisplayWord from '../components/DisplayWord.astro';
import { EVENTS } from '../data/events';

const nav = [
  { label: 'Starten', href: '/starten' },
  { label: 'Groeien', href: '/starten' },
  { label: 'Community', href: '/community' },
  { label: 'Faciliteiten', href: '/faciliteiten' },
  { label: 'Events', href: '/events' },
];
const iconArrowR = '<svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
---

<Base title="Dockwize — innovatie- en groeihub voor Zeeland">
  <!-- ============ HERO (exacte Dockwize-look) ============ -->
  <section class="relative md:min-h-[100svh] md:flex md:flex-col bg-[var(--color-ink)] text-white overflow-hidden">
    <img id="hero-media" src="/images/hero.jpg" alt="Dockwize Get Unlocked event" class="hero-kenburns absolute inset-0 w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-ink)]/60 via-[var(--color-ink)]/15 to-[var(--color-ink)]/30 pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-72 bg-gradient-to-t from-[var(--color-ink)]/70 to-transparent pointer-events-none"></div>

    <!-- Top: headline links, nav rechts -->
    <div class="relative z-20 mx-auto w-full max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-8 sm:pt-11 min-h-[56svh] md:min-h-0 md:flex md:items-start md:justify-between md:gap-8">
      <div class="max-w-2xl">
        <h1 class="font-extrabold tracking-[-0.03em] leading-[0.95] text-[clamp(2.7rem,4vw,4.2rem)] [text-shadow:0_2px_24px_rgba(0,0,0,0.25)]">
          Dockwize.<br />Unlocks your<br />potential.
        </h1>
        <button id="hero-pause" type="button" class="mt-6 inline-flex items-center gap-2 rounded-full bg-white/15 backdrop-blur-md border border-white/25 px-3.5 py-2 text-[12.5px] font-medium text-white hover:bg-white/25 transition active:scale-95">
          <span id="hero-pause-icon" class="grid place-items-center w-3.5 h-3.5">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
          </span>
          <span id="hero-pause-label">Pauzeer video</span>
        </button>
      </div>

      <nav class="hidden md:flex items-center gap-0.5 rounded-full bg-black/25 backdrop-blur-xl border border-white/15 p-1.5 shadow-[0_10px_34px_-12px_rgba(0,0,0,0.6)] shrink-0">
        {nav.map((n) => (
          <a href={n.href} class="px-3.5 py-2 rounded-full text-[14px] font-medium text-white/85 hover:text-white hover:bg-white/10 transition">{n.label}</a>
        ))}
        <button data-dw-menu class="ml-1 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold hover:brightness-105 transition active:scale-95">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          Menu
        </button>
      </nav>
      <button data-dw-menu class="md:hidden absolute top-8 sm:top-11 right-6 sm:right-10 inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] text-[14px] font-bold active:scale-95">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        Menu
      </button>
    </div>

    <div class="hidden md:block flex-1"></div>

    <!-- Onderaan: 3 zwevende blokken -->
    <div class="relative z-20 mx-auto w-full max-w-[1400px] px-6 sm:px-10 lg:px-16 pt-8 md:pt-0 pb-8 sm:pb-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-3.5">
        <!-- Blok 1: logo + ontdek waarom (licht, frosted) -->
        <div class="md:col-span-5 rounded-[22px] bg-white/80 backdrop-blur-xl border border-white/40 shadow-[var(--shadow-xl)] p-5 sm:p-7 flex items-center md:items-end justify-between gap-4 min-h-[150px] md:min-h-[160px]">
          <div class="flex items-center gap-2 select-none" title="Dockwize">
            <div class="logo-knockout font-extrabold uppercase tracking-[-0.045em] leading-[0.82] text-[28px]">
              <span class="block">Dock</span>
              <span class="block">Wize.</span>
            </div>
            <span class="logo-knockout-mark block w-[52px] h-[52px] shrink-0"></span>
            <span class="sr-only">Dockwize</span>
          </div>
          <a href="#fasen" class="hidden md:inline-flex shrink-0 items-center gap-2.5 sm:gap-3 text-[13px] sm:text-[14px] font-semibold text-[var(--color-ink)] group">
            <span class="grid place-items-center w-10 h-10 sm:w-11 sm:h-11 rounded-full bg-[var(--color-accent)] text-[var(--color-ink)] transition-transform group-hover:translate-y-0.5">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
            </span>
            Ontdek waarom
          </a>
        </div>

        <!-- Blok 2: foto + tekst (donker) -->
        <div class="md:col-span-4 rounded-[22px] bg-[var(--color-ink)] shadow-[var(--shadow-xl)] overflow-hidden flex items-stretch min-h-[148px]">
          <div class="w-2/5 shrink-0 relative overflow-hidden">
            <img src="/images/hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover object-[55%_center]" />
          </div>
          <div class="flex-1 p-4 sm:p-5 flex flex-col justify-between gap-3">
            <p class="text-[15px] font-bold leading-snug text-white">Met je bedrijf groeien en innoveren bij Dockwize?</p>
            <a href="#programmas" class="self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-4 py-1.5 text-[12.5px] font-semibold hover:brightness-110 transition active:scale-95">
              <span class="grid place-items-center w-6 h-6 rounded-full bg-white/15">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </span>
              Bekijk programma&apos;s
            </a>
          </div>
        </div>

        <!-- Blok 3: geel (CTA) -->
        <div class="md:col-span-3 rounded-[22px] bg-[var(--color-accent)] shadow-[var(--shadow-xl)] p-5 sm:p-6 flex flex-col justify-between gap-3 min-h-[148px]">
          <p class="text-[16px] font-extrabold leading-[1.14] tracking-tight text-[var(--color-ink)]">Starten met ondernemen? Dockwize geeft je een boost.</p>
          <button type="button" data-dwq-open class="self-start inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-4 py-1.5 text-[12.5px] font-semibold hover:brightness-110 transition active:scale-95">
            <span class="grid place-items-center w-6 h-6 rounded-full bg-white/15">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
            </span>
            Doe de Groeiscan
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Intro + content-grid (donker, à la dockwize.nl) ============ -->
  <section class="bg-[var(--color-ink)] text-white">
    <div class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 py-20 sm:py-28">
      <!-- Intro + checklist -->
      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-20 items-start" data-reveal>
        <div>
          <p class="text-[19px] sm:text-[24px] leading-[1.45] text-[var(--color-accent)] text-pretty max-w-xl">Als ondernemer wil jij de volgende stap maken. Dockwize helpt je daarbij! Met een programma op maat, innovatieve challenges en spraakmakende events. Vestig je bedrijf in onze inspirerende energiecentrale, waar het bruist van de energie.</p>
          <a href="/starten" class="mt-8 inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-5 py-2 text-[13.5px] font-semibold hover:brightness-110 transition active:scale-95">
            <span class="grid place-items-center w-7 h-7 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></span>
            Alles over Dockwize
          </a>
        </div>
        <ul class="space-y-4 lg:pt-2">
          {['Leren van ondernemers die exact één of twee stappen verder zijn.', 'Structureel werken aan strategie, groei en schaalbaarheid.', 'Je krijgt eerlijke feedback, geen applaus.', 'Je bouwt aan een netwerk dat ook buiten Dockwize voor je werkt.', 'Toegang tot kennis, events en financiering.'].map((t) => (
            <li class="flex items-start gap-3 border-b border-white/10 pb-4">
              <span class="mt-0.5 grid place-items-center w-5 h-5 rounded-full bg-[var(--color-cta)] text-white shrink-0"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
              <span class="text-[13.5px] sm:text-[14px] text-white/80 leading-snug">{t}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Gestapelde fotokaarten (onregelmatige masonry, à la dockwize.nl) -->
      <div class="mt-16 sm:mt-24 grid grid-cols-1 sm:grid-cols-12 gap-x-7 gap-y-7">
        <!-- Linkerkolom (smaller) -->
        <div class="sm:col-span-5 space-y-7 sm:space-y-14">
          <a href="/community" class="relative block rounded-[18px] overflow-hidden group" data-reveal>
            <img src="/images/collab.jpg" alt="Community" class="w-full object-cover aspect-[4/3] transition duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <span class="absolute left-5 bottom-4 right-5 text-white font-extrabold text-[16px] sm:text-[18px] leading-tight">Eén community, online en offline</span>
          </a>
          <a href="/events" class="relative block rounded-[18px] overflow-hidden group sm:w-[80%]" data-reveal>
            <img src="/images/hero.jpg" alt="Event terugblik" class="w-full object-cover aspect-[16/11] transition duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <span class="absolute left-5 bottom-4 right-5 text-white font-extrabold text-[16px] sm:text-[18px] leading-tight">Event terugblik</span>
          </a>
          <a href="/events" class="relative block rounded-[18px] overflow-hidden group" data-reveal>
            <img src="/images/fuckupnight.jpg" alt="Aftermovie" class="w-full object-cover aspect-[16/10] transition duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <span class="absolute left-5 bottom-4 right-5 text-white font-extrabold text-[16px] sm:text-[18px] leading-tight">Aftermovie: Fuck up night, digitalisering</span>
          </a>
        </div>
        <!-- Rechterkolom (breder, omlaag verschoven) -->
        <div class="sm:col-span-6 sm:col-start-7 sm:mt-32 space-y-7 sm:space-y-14">
          <a href="/community" class="relative block rounded-[18px] overflow-hidden group" data-reveal>
            <img src="/images/microgreens.jpg" alt="Innovator in energy, food & water" class="w-full object-cover aspect-[5/6] transition duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <span class="absolute left-5 bottom-5 right-5 text-white font-extrabold text-[17px] sm:text-[19px] leading-tight">Innovator in energy, food &amp; water</span>
          </a>
          <a href="/faciliteiten" class="relative block rounded-[18px] overflow-hidden group sm:w-[78%]" data-reveal>
            <img src="/images/eatmeet.jpg" alt="Eat & meet" class="w-full object-cover aspect-[4/3] transition duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <span class="absolute left-5 bottom-4 right-5 text-white font-extrabold text-[16px] sm:text-[18px] leading-tight">Eat &amp; meet</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Events ============ -->
  <DisplayWord word="events" class="pt-6" />
  <section class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 pb-16 sm:pb-20">
    <div class="grid sm:grid-cols-3 gap-4">
      {EVENTS.slice(0, 3).map((e) => (
        <a href={`/events/${e.slug}`} class="group rounded-[18px] bg-[var(--color-surface)] border border-[var(--color-border)] overflow-hidden shadow-[var(--shadow-sm)] hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5 transition" style="transition-timing-function:var(--ease-out-quint);" data-reveal>
          <div class="relative">
            <img src={e.image} alt={e.title} class="h-40 w-full object-cover" />
            <span class="absolute top-3 left-3 grid place-items-center w-11 h-11 rounded-xl bg-[var(--color-accent)] text-[var(--color-ink)] leading-none shadow"><span class="text-[16px] font-extrabold">{e.day}</span><span class="text-[9px] font-semibold uppercase">{e.month}</span></span>
          </div>
          <div class="p-5">
            <span class="text-[11px] font-semibold uppercase tracking-wide text-[var(--color-ink-3)]">{e.type}</span>
            <h3 class="mt-1.5 text-[15px] font-bold leading-snug text-[var(--color-ink)]">{e.title}</h3>
            <div class="mt-3 space-y-1 text-[12px] text-[var(--color-ink-3)]">
              <p class="flex items-center gap-1.5"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> {e.location}</p>
              <p class="flex items-center gap-1.5"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> {e.time}</p>
            </div>
            <span class="mt-4 inline-flex items-center gap-2 rounded-full bg-[var(--color-cta)] text-white pl-2 pr-4 py-1.5 text-[12.5px] font-semibold group-hover:brightness-110 transition"><span class="grid place-items-center w-6 h-6 rounded-full bg-white/15"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span> Event bekijken</span>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-7 text-center"><a href="/events" class="inline-flex items-center gap-2 text-[14px] font-semibold text-[var(--color-ink)] hover:gap-3 transition-all">Alle evenementen <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
  </section>

  <!-- ============ Testimonial (DuveFit) ============ -->
  <section class="mx-auto max-w-[1400px] px-6 sm:px-10 lg:px-16 py-16 sm:py-24">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center" data-reveal>
      <div>
        <div class="inline-flex items-baseline text-[22px] font-extrabold tracking-tight leading-none"><span class="text-[var(--color-ink)]">DUVE</span><span class="text-[var(--color-cta)]">FIT</span></div>
        <p class="mt-5 text-[14px] font-bold text-[var(--color-ink)]">Wouter en Paula Duvekot</p>
        <p class="text-[12px] text-[var(--color-ink-3)]">Ondernemers</p>
        <p class="mt-5 text-[14px] leading-relaxed text-[var(--color-ink-2)] max-w-md">Niet sporten door mentale of fysieke beperkingen is wat Wouter en Paula Duvekot betreft verleden tijd. Deze broer en zus runnen samen Duvefit, de sportschool in Goes waar iedereen welkom is. Met zorg op maat in de vorm van sport en spel houden ze doelgroepen die buiten de maatschappij dreigen te vallen betrokken.</p>
        <p class="mt-8 text-[clamp(1.4rem,2.6vw,2.1rem)] font-extrabold tracking-tight leading-[1.12] text-[var(--color-ink)] text-pretty">“Het &lsquo;Jouw programma&rsquo; is een fantastische mogelijkheid om jezelf en je bedrijf te ontwikkelen.”</p>
      </div>
      <div class="rounded-[20px] overflow-hidden shadow-[var(--shadow-lg)]"><img src="/images/collab.jpg" alt="Wouter en Paula Duvekot" class="w-full h-[clamp(300px,40vw,460px)] object-cover" /></div>
    </div>
  </section>

  <!-- ============ Footer ============ -->
  <SiteFooter />

  <SiteMenu />

  <GroeiscanWidget contactUrl="#contact" />

  <script is:inline>
    (function () {
      // Pauzeer / speel de hero ken-burns
      const media = document.getElementById('hero-media');
      const pauseBtn = document.getElementById('hero-pause');
      let paused = false;
      const playIcon = '<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M7 5v14l12-7z"/></svg>';
      const pauseIcon = '<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>';
      pauseBtn?.addEventListener('click', () => {
        paused = !paused;
        if (media) media.style.animationPlayState = paused ? 'paused' : 'running';
        const label = document.getElementById('hero-pause-label');
        const icon = document.getElementById('hero-pause-icon');
        if (label) label.textContent = paused ? 'Speel video' : 'Pauzeer video';
        if (icon) icon.innerHTML = paused ? playIcon : pauseIcon;
      });
    })();
  </script>
</Base>
